# ═══════════════════════════════════════════════════
# AgentSwarm Environment Configuration
# Copy this to .env and fill in your keys
# ═══════════════════════════════════════════════════

# ── Attena API (free, no key needed for 30req/min) ──
ATTENA_BASE_URL=https://attena-api.fly.dev/api/search/
ATTENA_API_KEY=                   # optional, for 300req/min

# ── Claude API (for News Reactor agent) ──
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── News API (for News Reactor agent) ──
# Get from: https://newsapi.org/
NEWS_API_KEY=

# ── Kalshi Exchange ──
# Apply at: https://kalshi.com/ (US only)
KALSHI_EMAIL=
KALSHI_PASSWORD=

# ── Polymarket Exchange ──
# Needs a Polygon wallet with USDC
POLYMARKET_PRIVATE_KEY=           # wallet private key (⚠️ use a dedicated hot wallet!)
POLYMARKET_RPC=https://polygon-rpc.com
POLYMARKET_CLOB=https://clob.polymarket.com

# ── Infrastructure ──
POSTGRES_DSN=postgres://swarm:swarm@localhost:5432/agentswarm?sslmode=disable
REDIS_ADDR=localhost:6379
NATS_URL=nats://localhost:4222

# ── Agent Tuning ──
POLL_INTERVAL=30s
MAX_POSITION_SIZE=500
CIRCUIT_BREAKER_PCT=0.05
CIRCUIT_BREAKER_WINDOW=30m
HTTP_PORT=8080
